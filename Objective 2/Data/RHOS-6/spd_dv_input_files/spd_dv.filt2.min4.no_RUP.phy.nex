end;
begin paup;
	outgroup pops.atratulus;
	set outroot=monophyl;
	svdq treemodel=mscoalescent taxpartition=pops evalQuartets=all nthreads=ncpus bootstrap=standard nreps=100 treeFile=dv_bootstraps.tre;
	savetrees format=newick brlens=yes trees=all file=spd_dv_svdq_bootstrap.tre;
end;
