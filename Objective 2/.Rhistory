# --- TRAIT PROFILES PER GROUP ---
# Add group assignments back to trait matrix
trait_profiles <- trait_matrix %>%
as.data.frame() %>%
dplyr::mutate(
Species = rownames(trait_matrix),
Functional_Group = as.factor(kmeans_result$cluster)
)
# Mean trait values per group
group_means <- trait_profiles %>%
dplyr::group_by(Functional_Group) %>%
dplyr::summarise(across(where(is.numeric), ~ round(mean(., na.rm = TRUE), 2))) %>%
as.data.frame()
cat("Mean trait values per functional group:\n")
print(group_means)
# --- ISOLATE GROUP 5 ---
group5_species <- trait_profiles %>%
dplyr::filter(Functional_Group == 5)
cat("\nGroup 5 species and their traits:\n")
print(group5_species)
# Compare Group 5 mean vs all other groups
group5_mean <- trait_profiles %>%
dplyr::mutate(is_group5 = ifelse(Functional_Group == 5, "Group 5", "Other")) %>%
dplyr::group_by(is_group5) %>%
dplyr::summarise(across(where(is.numeric), ~ round(mean(., na.rm = TRUE), 2))) %>%
as.data.frame()
cat("\nGroup 5 vs all others â€” mean trait comparison:\n")
print(group5_mean)
# --- FIND TRAITS WHERE GROUP 5 DIFFERS MOST ---
g5_row <- group5_mean[group5_mean$is_group5 == "Group 5", -1]
other_row <- group5_mean[group5_mean$is_group5 == "Other", -1]
trait_diff <- abs(g5_row - other_row)
trait_diff_sorted <- sort(unlist(trait_diff), decreasing = TRUE)
cat("\nTraits ranked by how different Group 5 is from all others:\n")
print(round(trait_diff_sorted, 3))
