Ice + Tectonic + Topography + SeaLevel +
AREAKM2 + PATCHES +
FECUNDITY + LONGEVITY + MAXTL + Anadromy +
snapped_lat,
data = dat_lm
)
car::vif(lm_vif)
phyr_pglmm_null <- pglmm(
He ~ 1 +
# random effects
(1 | Study_id) +
(1 | Spec_Latin_GenDivRange__),
data = dat_lm,
family = "gaussian",
cov_ranef = list(Spec_Latin_GenDivRange = phylo)
)
