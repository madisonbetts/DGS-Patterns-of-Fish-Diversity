get_clades <- function(tree) {
n <- length(tree$tip.label)
clades <- list()
for (node in (n + 1):(n + tree$Nnode)) {
tips <- extract.clade(tree, node)$tip.label
clades[[length(clades) + 1]] <- sort(tips)
}
# remove entire tree
clades <- clades[sapply(clades, length) < length(tree$tip.label)]
# remove clades that have any of the OG in them
clades <- clades[!sapply(clades, function(x) any(x %in% OG))]
}
clade_list <- lapply(trees, get_clades)
clade_strings <- lapply(clade_list, function(clades) {
sapply(clades, function(x) paste(x, collapse = ","))
})
#shared <- Reduce(intersect, clade_strings)
# flatten
all_clades <- unlist(clade_strings)
# count occurrences
clade_counts <- table(all_clades)
# retain clades present in >= 2 elements
shared <- names(clade_counts[clade_counts >= 2])
shared_clades <- lapply(shared, function(x) unlist(strsplit(x, ",")))
shared_clades <- shared_clades[lengths(shared_clades) <= 16]
is_subset <- function(a, b) any(a %in% b)
keep_maximal <- function(clades) {
keep <- rep(TRUE, length(clades))
for (i in seq_along(clades)) {
for (j in seq_along(clades)) {
if (i != j && is_subset(clades[[i]], clades[[j]])) {
if (length(clades[[i]]) < length(clades[[j]])) {
keep[i] <- FALSE
}
}
}
}
clades[keep]
}
max_clades <- keep_maximal(shared_clades)
# get tips that arent in max_clades
in_clade <- unlist(max_clades)
not_in <- tips[which(!(IG %in% in_clade))]
not_in
length(max_clades)
max_clades[[length(max_clades) + 1]] <- not_in
length(max_clades)
View(max_clades)
write_json(max_clades, "results/clades.txt", auto_unbox = TRUE)
