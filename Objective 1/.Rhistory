geom_smooth(method = "lm", color = "darkgreen", se = F)+
xlab("Trust in Authority")+
ylab("Belief in Evolution")+
ggtitle("Trust in Authority vs Belief in Evolution")+
theme_classic()
# ecuation level vs belief
ggplot(evol_soc_clean, aes(x = education_int, y = evol_belief))+
geom_jitter(color = "mediumpurple3")+
geom_smooth(method = "lm", color = "darkgreen", se = F)+
xlab("Education Level")+
ylab("Belief in Evolution")+
