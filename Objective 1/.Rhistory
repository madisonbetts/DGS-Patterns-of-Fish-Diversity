# Species Life History
FECUNDITY + LONGEVITY + MAXTL + Anadromy
# random effects
(1 | Study_id) +
(1 | Spec_Latin_GenDivRange__),
data = dat_lm,
family = "gaussian",
cov_ranef = list(Spec_Latin_GenDivRange = phylo),
REML = F
)
