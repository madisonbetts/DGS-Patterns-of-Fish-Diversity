head(evol_soc)
# select certain columns and rename for brevity
evol_soc_clean <- evol_soc %>%
select(age = "What.is.your.age." ,
trust_lvl = "How.much.do.you.trust.social.authority.figures..e.g...politicians..scientists..and.doctors..",
education = "What.is.the.highest.level.of.education.you.have.completed.",
evol_belief = "How.much.do.you.agree.with.this.statement....Human.beings..as.we.know.them.today..derived.from.an.earlier.species.of.animals..")
# inspect data
head(evol_soc_clean)
str(evol_soc_clean)
# 2. Convert to ordered factor, then to numeric
evol_soc_clean$education_int <- as.integer(factor(evol_soc_clean$education,
levels = edu_order))
View(evol_soc_clean)
