knitr::opts_chunk$set(echo = TRUE)
# load packages
library(dplyr)
library(tidyverse)
library(ggplot2)
# make sure working directory is where you have the data downloaded
setwd("C:/Users/cgher/Documents/IB302/lab2")
# load dataset
evol_soc <- read.csv("Evolution and Society Lab SP2025 (Responses) - Form Responses 1.csv")
str(evol_soc)
# select certain columns and rename for brevity
evol_soc_clean <- evol_soc %>%
select(age = "What.is.your.age." ,
trust_lvl = "How.much.do.you.trust.social.authority.figures..e.g...politicians..scientists..and.doctors..",
education = "What.is.the.highest.level.of.education.you.have.completed.",
evol_belief = "How.much.do.you.agree.with.this.statement....Human.beings..as.we.know.them.today..derived.from.an.earlier.species.of.animals..")
# inspect data
head(evol_soc_clean)
str(evol_soc_clean)
# define the correct order
edu_order <- c("High school", "1 year of university education",
"2 years of university education", "3 years of university education",
"University degree", "Masters degree or equivalent", "PhD or equivalent")
# convert to ordered factor, then to integer
evol_soc_clean$education_int <- as.integer(factor(evol_soc_clean$education,
levels = edu_order))
# age vs belief
ggplot(evol_soc_clean, aes(x = age, y = evol_belief))+
geom_point(color = "mediumpurple3")+
xlab("Age")+
ylab("Belief in Evolution")+
ggtitle("Age vs Belief in Evolution")+
theme_classic()
# with geom_jitter()
ggplot(evol_soc_clean, aes(x = age, y = evol_belief))+
geom_jitter(color = "mediumpurple3")+
xlab("Age")+
ylab("Belief in Evolution")+
ggtitle("Age vs Belief in Evolution")+
theme_classic()
# trust in authority vs belief
ggplot(evol_soc_clean, aes(x = trust_lvl, y = evol_belief))+
geom_jitter(color = "mediumpurple3")+
xlab("Trust in Authority")+
ylab("Belief in Evolution")+
ggtitle("Trust in Authority vs Belief in Evolution")+
theme_classic()
# education level vs belief
ggplot(evol_soc_clean, aes(x = education_int, y = evol_belief))+
geom_jitter(color = "mediumpurple3")+
xlab("Education Level")+
ylab("Belief in Evolution")+
ggtitle("Education Level vs Belief in Evolution")+
theme_classic()
# age vs belief
lm_age <- lm(evol_belief ~ age, data = evol_soc_clean)
summary(lm_age)
# trust in authority vs belief
lm_trust <- lm(evol_belief ~ trust_lvl, data = evol_soc_clean)
summary(lm_trust)
# education level vs belief
lm_edu <- lm(evol_belief ~ education_int, data = evol_soc_clean)
summary(lm_edu)
# age vs belief
ggplot(evol_soc_clean, aes(x = age, y = evol_belief))+
geom_jitter(color = "mediumpurple3")+
geom_smooth(method = "lm", color = "darkgreen", se = F)+
xlab("Age")+
ylab("Belief in Evolution")+
ggtitle("Age vs Belief in Evolution")+
theme_classic()
# trust in authority vs belief
ggplot(evol_soc_clean, aes(x = trust_lvl, y = evol_belief))+
geom_jitter(color = "mediumpurple3")+
geom_smooth(method = "lm", color = "darkgreen", se = F)+
xlab("Trust in Authority")+
ylab("Belief in Evolution")+
ggtitle("Trust in Authority vs Belief in Evolution")+
theme_classic()
# education level vs belief
ggplot(evol_soc_clean, aes(x = education_int, y = evol_belief))+
geom_jitter(color = "mediumpurple3")+
geom_smooth(method = "lm", color = "darkgreen", se = F)+
xlab("Education Level")+
ylab("Belief in Evolution")+
ggtitle("Education Level vs Belief in Evolution")+
theme_classic()
# education level vs belief
ggplot(evol_soc_clean, aes(x = education_int, y = evol_belief, color = age))+
geom_jitter()+
geom_smooth(method = "lm", color = "darkgreen", se = F)+
xlab("Education Level")+
ylab("Belief in Evolution")+
ggtitle("Education Level vs Belief in Evolution")+
theme_classic()
# education level vs belief
ggplot(evol_soc_clean, aes(x = education_int, y = evol_belief, color = age))+
geom_jitter()+
scale_color_viridis_c()+
geom_smooth(method = "lm", color = "darkgreen", se = F)+
xlab("Education Level")+
ylab("Belief in Evolution")+
ggtitle("Education Level vs Belief in Evolution")+
theme_classic()
# education level vs belief
ggplot(evol_soc_clean, aes(x = education_int, y = evol_belief, color = age))+
geom_jitter()+
scale_color_brewer()+
geom_smooth(method = "lm", color = "darkgreen", se = F)+
xlab("Education Level")+
ylab("Belief in Evolution")+
ggtitle("Education Level vs Belief in Evolution")+
theme_classic()
library(RColorBrewer)
# education level vs belief
ggplot(evol_soc_clean, aes(x = education_int, y = evol_belief, color = age))+
geom_jitter()+
scale_color_brewer()+
geom_smooth(method = "lm", color = "darkgreen", se = F)+
xlab("Education Level")+
